LOGS = "-1003941141635"
## Where ban / unban / appeal / admin action log messages are sent.
## Can be a standalone channel ID or a forum thread (chat_id/thread_id).
## U can use "MAIN_GROUP" to post directly to the main group.
## U can use "auto" if MAIN_GROUP is a forum — it will automatically create
