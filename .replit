modules = ["python-3.13"]
[agent]
expertMode = true
stack = "FLASK_VANILLA_JS"

[nix]
channel = "stable-25_05"
packages = ["openssl", "postgresql"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Tests (TDD)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m tcbot"

[[workflows.workflow]]
name = "Run Tests (TDD)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m pytest tests/ -v"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "main:app"]

[userenv]

[userenv.shared]
DB_NAME = "tcbot"
COMMUNITY_NAME = "𝘛𝘊𝘍 - 𝘛𝘳𝘢𝘯𝘴𝘴𝘪𝘰𝘯 𝘊𝘰𝘳𝘦 𝘍𝘦𝘥𝘦𝘳𝘢𝘵𝘪𝘰𝘯"
PREFIXES = "[\"/\", \"!\", \".\"]"
PORT = "8080"
MAIN_GROUP = "-1003872207988"
MAIN_CHANNEL = "-1003852970764"
PROOFS = "-1003872207988/67"
LOGS = "-1003941141635"
LOGS_ERRORS = "-1003872207988/279"
APPEALS = "-1003872207988/12"
PROOF_TIMEOUT_SECONDS = "100"
APPEAL_TIMEOUT_SECONDS = "600"
EXTEND_GROUP = ""
ALBUM_DEBOUNCE_SECONDS = "2"
OWNER_ID = "7146954165"
APPEAL_DISCUSSION_TOPIC = "11"
LOG_LEVEL = "INFO"
MODULES_LOAD = ""
MODULES_NO_LOAD = ""
