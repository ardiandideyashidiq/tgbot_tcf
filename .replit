modules = ["python-3.11", "nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TCF Bot"

[[workflows.workflow]]
name = "TCF Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m tgbot_tcf"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "vm"
run = ["python", "-m", "tgbot_tcf"]
