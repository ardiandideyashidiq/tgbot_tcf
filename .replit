run = "python -m tgbot_tcf"
language = "python3"
modules = ["python-3.11"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TCF Bot"

[[workflows.workflow]]
name = "TCF Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m tgbot_tcf"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true
