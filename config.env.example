## -- Remove this line --

BOT_TOKEN = ""                  # Your Telegram bot token, get it from BotFather.
OWNER_ID = ""                   # Your Telegram user ID, get it from @userinfobot or similar.

MONGODB_URI = ""                # Your MongoDB connection string, get it from your MongoDB provider. eg: "mongodb+srv://username:password@cluster.mongodb.net/database"
DB_NAME = ""                    # The name of the database to use in MongoDB. eg: "my_bot_db"

COMMUNITY_NAME = ""             # The name of your Telegram community, used in messages. eg: "My Awesome Community"
PREFIXES = ["/", "!", "."]      # List of command prefixes to recognize. eg: ["/", "!"] (if not set defaults to ["/"] default telegram bot prefix)

PORT = "8000"                   # The port number for the web server to listen on. eg: "8000" or "5050" or "auto"
## if PORT is not set, it will default to "8080".
## If set to "auto", it will automatically find an available port in the system for better security and flexibility.

MAIN_GROUP = ""                 # The Telegram group or forum chat ID your community uses. eg: -1001234567890 (must be a negative number for groups and forums)
MAIN_CHANNEL = ""               # The Telegram channel ID your community uses. eg: -1001234567890 (must be a negative number for channels)

PROOFS = ""
## Proof Channel IDs. eg: "-1001234567890" (must be a negative number for channels).
## U can use  Thread IDs of forum as well. eg: "-1001234567890/123456" (must be a negative number for channels and threads)

LOGS = ""
## Log Channel IDs. eg: "-1001234567890" (must be a negative number for channels).
## U can use  Thread IDs of forum as well. eg: "-1001234567890/123456" (must be a negative number for channels and threads)
## U can use "MAIN_GROUP"
## U can use "auto" if the MAIN_GROUP is a forum, it will automatically create a thread for logs and use it as LOGS, with the name topic "Logs" and with emoji "📜".

LOGS_ERRORS = "" # (Optional)
## Log Channel IDs. eg: "-1001234567890" (must be a negative number for channels).
## U can use  Thread IDs of forum as well. eg: "-1001234567890/123456" (must be a negative number for channels and threads)
## U can use "MAIN_GROUP"
## U can use "auto" if the MAIN_GROUP is a forum, it will automatically create a thread for logs and use it as LOGS, with the name topic "Logs Error" and with emoji Virus "🦠".

APPEALS = ""
## Appeal Channel IDs. eg: "-1001234567890" (must be a negative number for channels).
## U can use  Thread IDs of forum as well. eg: "-1001234567890/123456" (must be a negative number for channels and threads)
## U can use "MAIN_GROUP"
## U can use "auto" if the MAIN_GROUP is a forum, it will automatically create a thread for appeals and use it as APPEALS, with the name topic "Appeals" and with emoji "⚖️".

PROOF_TIMEOUT_SECONDS = 100 # Time in seconds to wait for users to submit their proof after they start the verification process. Default is 100 seconds (1 minute and 40 seconds).
APPEAL_TIMEOUT_SECONDS = 600

EXTEND_GROUP = "" # (Optional)
ALBUM_DEBOUNCE_SECONDS = 2 # Time in seconds to wait before processing the next media in an album, to ensure all media are received. Default is 2 seconds.