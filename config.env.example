## -- Remove this line after filling in your values --

## ---------------------------------------------------------------------------
## Core — required for the bot to start
## ---------------------------------------------------------------------------

BOT_TOKEN = ""
## Your Telegram bot token. Get it from @BotFather on Telegram.
## eg: "7123456789:AAF..."

OWNER_ID = ""
## Your Telegram user ID (numeric). Get it from @userinfobot or @getidsbot.
## This user has full owner-level access to the bot.
## eg: "7146954165"

MONGODB_URI = ""
## Your MongoDB connection string.
## eg: "mongodb+srv://username:password@cluster.example.mongodb.net/"

DB_NAME = ""
## The MongoDB database name to use.
## eg: "tcbot"

## ---------------------------------------------------------------------------
## Community settings
## ---------------------------------------------------------------------------

COMMUNITY_NAME = ""
## Display name of your federation / community, used in bot messages.
## eg: "TCF - Transsion Core Federation"

PREFIXES = ["/", "!", "."]
## Command prefixes the bot will recognize. Must be a list.
## eg: ["/", "!"] or just ["/"]
## Defaults to ["/"] (standard Telegram prefix) if not set.

## ---------------------------------------------------------------------------
## Web server
## ---------------------------------------------------------------------------

PORT = "5000"
## Port for the Flask keep-alive / health-check server.
## Set to "auto" to let the system pick an available port.
## Defaults to 5000 if not set or set to "auto".

## ---------------------------------------------------------------------------
## Telegram channels / groups
## ---------------------------------------------------------------------------

MAIN_GROUP = ""
## Chat ID of your main community group or forum.
## Must be a negative number for groups/supergroups.
## eg: "-1001234567890"

MAIN_CHANNEL = ""
## (Optional) Chat ID of your main community announcement channel.
## eg: "-1001234567890"

EXTEND_GROUP = ""
## (Optional) Chat ID of a secondary / staff-only group.
## The greeting handler watches this group in addition to MAIN_GROUP.
## eg: "-1001234567890"

PROOFS = ""
## Where ban proof media is uploaded.
## Can be a channel ID or a forum thread (chat_id/thread_id).
## eg: "-1001234567890" or "-1001234567890/67"

LOGS = ""
## Where ban / unban / appeal / admin log messages are sent.
## Can be a channel ID or a forum thread (chat_id/thread_id).
## Special values:
##   "MAIN_GROUP"  — post directly to the main group (no thread)
##   "auto"        — create a "Logs 📜" topic automatically if MAIN_GROUP is a forum
## eg: "-1001234567890" or "-1001234567890/42"

LOGS_ERRORS = "" # (Optional)
## Separate destination for error-level logs.
## Same format as LOGS. If empty, errors go to the same place as LOGS.
## Special values:
##   "MAIN_GROUP"  — post to the main group
##   "auto"        — create a "Logs Error 🦠" topic automatically if MAIN_GROUP is a forum
## eg: "-1001234567890/279"

APPEALS = ""
## Where submitted appeal messages are forwarded for record-keeping.
## Can be a channel ID or a forum thread (chat_id/thread_id).
## Special values:
##   "MAIN_GROUP"  — post to the main group
##   "auto"        — create an "Appeals ⚖️" topic automatically if MAIN_GROUP is a forum
## eg: "-1001234567890/12"

APPEAL_DISCUSSION_TOPIC = ""
## Thread ID (integer) inside MAIN_GROUP where appeal review cards are posted.
## Staff vote here using the Approve / Reject buttons.
## This is only the thread_id — the chat is always MAIN_GROUP.
## eg: "11"

## ---------------------------------------------------------------------------
## Timeouts
## ---------------------------------------------------------------------------

PROOF_TIMEOUT_SECONDS = 100
## How long (in seconds) to wait for the admin to upload ban proof.
## After this time the /tcban conversation ends with no ban issued.
## Default: 100 seconds.

APPEAL_TIMEOUT_SECONDS = 600
## How long (in seconds) to keep an active appeal conversation open.
## After this time the conversation ends automatically.
## Default: 600 seconds (10 minutes).

ALBUM_DEBOUNCE_SECONDS = 2
## How long (in seconds) to buffer album media before processing.
## Telegram sends album items as separate messages; this window lets them
## all arrive before the ban executor runs.
## Default: 2 seconds.

## ---------------------------------------------------------------------------
## Logging
## ---------------------------------------------------------------------------

LOG_LEVEL = INFO
## Log verbosity for the bot's own logger.
## Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
## Default: INFO
## Use DEBUG for verbose output during development.

## ---------------------------------------------------------------------------
## Module control (advanced)
## ---------------------------------------------------------------------------

MODULES_LOAD = ""
## Comma-separated list of module filenames to load exclusively (whitelist).
## When set, ONLY these modules are loaded. Leave empty to load everything.
## eg: "banning,appeals,admins"

MODULES_NO_LOAD = ""
## Comma-separated list of module filenames to skip (blacklist).
## These modules are excluded from loading. Ignored when MODULES_LOAD is set.
## eg: "maintenance,broadcasting"
